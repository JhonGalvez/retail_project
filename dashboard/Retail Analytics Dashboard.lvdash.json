{
  "datasets": [
    {
      "name": "39ac4ecd",
      "displayName": "ventas_por_categoria",
      "queryLines": [
        "SELECT year_month, product_category, total_revenue\r\n",
        "FROM retail_project_prod.gold.ventas_por_categoria\r\n",
        "ORDER BY year_month"
      ]
    },
    {
      "name": "db85d5a7",
      "displayName": "top_productos",
      "queryLines": [
        "SELECT product_name, department, total_pedidos\r\n",
        "FROM retail_project_prod.gold.top_productos\r\n",
        "ORDER BY total_pedidos DESC"
      ]
    },
    {
      "name": "42c2b995",
      "displayName": "eficiencia_marketing",
      "queryLines": [
        "SELECT product_category, roi_marketing, total_revenue\r\n",
        "FROM retail_project_prod.gold.eficiencia_marketing\r\n",
        "ORDER BY roi_marketing DESC"
      ]
    },
    {
      "name": "b22f7e7c",
      "displayName": "actividad_por_horario",
      "queryLines": [
        "SELECT time_slot, SUM(total_ordenes) AS ordenes_totales\r\n",
        "FROM retail_project_prod.gold.actividad_por_horario\r\n",
        "GROUP BY time_slot\r\n",
        "ORDER BY ordenes_totales DESC"
      ]
    },
    {
      "name": "56d35910",
      "displayName": "kpi_resumen",
      "queryLines": [
        "SELECT\r\n",
        "    ROUND(SUM(total_revenue), 2)         AS revenue_total,\r\n",
        "    SUM(total_units_sold)                AS unidades_totales,\r\n",
        "    COUNT(DISTINCT product_category)     AS categorias\r\n",
        "FROM retail_project_prod.gold.ventas_por_categoria"
      ]
    }
  ],
